# Copy this file to .env and fill in your values
# cp .env.example .env

# Path to the trained model checkpoint (relative to project root)
MODEL_PATH=models/best_model.pth

# Probability threshold: predictions above this are considered positive
PREDICTION_THRESHOLD=0.5

# OpenAI API key (required for report generation, chat, and RAG embeddings)
OPENAI_API_KEY=sk-your-api-key-here

# Which OpenAI chat model to use
OPENAI_MODEL=gpt-4.1-mini

# LLM temperature (0 = deterministic, 1 = creative)
OPENAI_TEMPERATURE=0.2

# CORS: comma-separated origins, or * for any (e.g. https://your-frontend.com)
CORS_ORIGINS=*
